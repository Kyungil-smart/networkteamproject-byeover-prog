%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5477a2129d0036046a0b16fe88702757, type: 3}
  m_Name: LoadingTipDatabase
  m_EditorClassIdentifier: Assembly-CSharp::DeadZone.Actors.UI.LoadingTipDatabase
  tips:
  - category: 0
    message: "WASD\uB85C \uC774\uB3D9\uD569\uB2C8\uB2E4. \uCD1D\uC54C\uC740 \uC774\uB3D9
      \uC2DC\uD0A4\uC9C0 \uBABB\uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "\uB9C8\uC6B0\uC2A4\uB85C \uC870\uC900\uC810\uC744 \uC6C0\uC9C1\uC785\uB2C8\uB2E4.
      \uCEE4\uC11C\uAC00 \uACE7 \uC0DD\uC874\uC120\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "\uC88C\uD074\uB9AD\uC73C\uB85C \uBC1C\uC0AC\uD569\uB2C8\uB2E4. \uBE57\uB098\uAC04
      \uD0C4\uC740 \uC0AC\uACFC\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "\uC6B0\uD074\uB9AD\uC73C\uB85C \uC870\uC900\uD569\uB2C8\uB2E4. \uAE09\uD558\uBA74
      \uC3D8\uACE0, \uC0B4\uACE0 \uC2F6\uC73C\uBA74 \uC870\uC900\uD558\uC138\uC694."
    imageKey: Default
  - category: 0
    message: "R\uD0A4\uB85C \uC7AC\uC7A5\uC804\uD569\uB2C8\uB2E4. \uBE48 \uD0C4\uCC3D\uC73C\uB85C
      \uC6A9\uAE30 \uB0B4\uC9C0 \uB9C8\uC138\uC694."
    imageKey: Default
  - category: 0
    message: "F\uD0A4\uB85C \uBB38, \uC0C1\uC790, \uC2DC\uC124\uACFC \uC0C1\uD638\uC791\uC6A9\uD569\uB2C8\uB2E4.
      \uBB38\uC740 \uC5B4\uB5BB\uAC8C \uC5F4\uC8E0?"
    imageKey: Default
  - category: 0
    message: "Tab\uD0A4\uB85C \uC778\uBCA4\uD1A0\uB9AC\uB97C \uC5FD\uB2C8\uB2E4.
      \uC815\uB9AC\uB294 \uC0DD\uC874\uC790\uC758 \uAE30\uBCF8 \uC18C\uC591\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "M\uD0A4\uB85C \uC9C0\uB3C4\uB97C \uD655\uC778\uD569\uB2C8\uB2E4. \uAE38
      \uC783\uB294 \uAC83\uB3C4 \uC804\uB7B5\uC740 \uC544\uB2D9\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "Esc\uD0A4\uB85C \uBA54\uB274\uB97C \uC5FD\uB2C8\uB2E4. \uD604\uC2E4
      \uB3C4\uD53C\uB294 \uC9C0\uC6D0\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "Space\uB85C \uAD6C\uB974\uAE30\uB97C \uC0AC\uC6A9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uCD1D\uC54C\uBCF4\uB2E4 \uBE60\uB974\uC9C4 \uC54A\uC544\uB3C4, \uB9DE\uB294
      \uC704\uCE58\uB294 \uBC14\uAFC0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "\uAD6C\uB974\uAE30\uB294 \uC2A4\uD0DC\uBBF8\uB098\uB97C \uC18C\uBAA8\uD569\uB2C8\uB2E4.
      \uB0A8\uBC1C\uD558\uBA74 \uBA4B\uC788\uAC8C \uC8FD\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "Shift\uB97C \uB204\uB974\uACE0 \uC788\uC73C\uBA74 \uB2EC\uB9BD\uB2C8\uB2E4.
      \uB3C4\uB9DD\uB3C4 \uC804\uC220\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "1\uBC88\uC740 \uBCF4\uC870\uBB34\uAE30, 2~3\uBC88\uC740 \uC8FC\uBB34\uAE30
      \uC2AC\uB86F\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "4~9\uBC88\uC740 \uD035\uC2AC\uB86F\uC785\uB2C8\uB2E4. \uD68C\uBCF5\uD15C\uC744
      \uB123\uC5B4\uB450\uBA74 \uD6C4\uD68C\uAC00 \uC904\uC5B4\uB4ED\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "T\uD0A4\uB85C \uD018\uC2A4\uD2B8 \uCC3D\uC744 \uD655\uC778\uD560 \uC218
      \uC788\uC2B5\uB2C8\uB2E4. \uBAA9\uC801 \uC5C6\uB294 \uD30C\uBC0D\uC740 \uC0B0\uCC45\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uBB34\uAC70\uC6B4 \uC7A5\uBE44\uB97C \uB9CE\uC774 \uB4E4\uBA74 \uC774\uB3D9\uC774
      \uB290\uB824\uC9D1\uB2C8\uB2E4. \uC695\uC2EC\uB3C4 \uBB34\uAC8C\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uC778\uBCA4\uD1A0\uB9AC\uAC00 \uAF49 \uCC3C\uB2E4\uBA74, \uC815\uB9D0
      \uD544\uC694\uD55C \uAC83\uACFC \uADF8\uB0E5 \uC544\uAE4C\uC6B4 \uAC83\uC744
      \uAD6C\uBD84\uD558\uC138\uC694."
    imageKey: Default
  - category: 2
    message: "\uD0C4\uC57D \uB4F1\uAE09\uC744 \uD655\uC778\uD558\uC138\uC694. LP,
      BP, AP\uB294 \uC774\uB984\uBCF4\uB2E4 \uACB0\uACFC\uAC00 \uB2E4\uB985\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uC88B\uC740 \uCD1D\uBCF4\uB2E4 \uB9DE\uB294 \uD0C4\uC774 \uB354 \uC911\uC694\uD560
      \uB54C\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uAC12\uBE44\uC2FC \uADC0\uC911\uD488\uC740 \uC81C\uC791\uD560 \uC218
      \uC5C6\uC2B5\uB2C8\uB2E4. \uD6D4\uCE58\uB4EF \uC8FC\uC6CC\uC57C \uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uC7A0\uAE34 \uAD6C\uC5ED\uC77C\uC218\uB85D \uC88B\uC740 \uC544\uC774\uD15C\uC774
      \uB098\uC62C \uD655\uB960\uC774 \uB192\uC2B5\uB2C8\uB2E4. \uBB3C\uB860 \uC8FD\uC744
      \uD655\uB960\uB3C4 \uB192\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uC544\uC774\uD15C\uC744 \uC8FC\uC6E0\uB2E4\uACE0 \uB05D\uC774 \uC544\uB2D9\uB2C8\uB2E4.
      \uD0C8\uCD9C\uD574\uC57C \uC9C4\uC9DC \uB0B4 \uAC83\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uAC00\uBC29\uC5D0 \uB4E4\uC5B4\uAC04 \uC544\uC774\uD15C\uC740 \uD76C\uB9DD\uC785\uB2C8\uB2E4.
      \uC0AC\uB9DD\uD558\uBA74 \uB0A8\uC758 \uD76C\uB9DD\uC774 \uB429\uB2C8\uB2E4."
    imageKey: Default
  - category: 1
    message: "\uBC29\uC5B4\uAD6C\uB294 \uBB34\uC801\uC774 \uC544\uB2D9\uB2C8\uB2E4.
      \uC218\uBA85\uC744 \uC870\uAE08 \uBE4C\uB824\uC904 \uBFD0\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 1
    message: "\uD5EC\uBA67\uC740 \uBA38\uB9AC\uB97C \uC9C0\uCF1C\uC90D\uB2C8\uB2E4.
      \uC0DD\uAC01\uC740 \uC9C1\uC811 \uD558\uC154\uC57C \uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 1
    message: "\uC801\uC774 \uBCF4\uC774\uC9C0 \uC54A\uC544\uB3C4 \uC18C\uB9AC\uB97C
      \uB4E4\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uB3C4 \uB9C8\uCC2C\uAC00\uC9C0\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 1
    message: "\uC5C4\uD3D0\uBB3C\uC740 \uC7A5\uC2DD\uC774 \uC544\uB2D9\uB2C8\uB2E4.
      \uBCBD \uB4A4\uC5D0\uC11C \uC0DD\uC874\uD558\uBA74 \uC77C\uB2E8 \uD300\uC6D0\uC758
      \uBD84\uB178\uAC8C\uC774\uC9C0\uB294 \uC904\uC5B4\uB4ED\uB2C8\uB2E4."
    imageKey: Default
  - category: 1
    message: "\uCCB4\uB825\uC774 \uB0AE\uC744 \uB550 \uC2F8\uC6C0\uBCF4\uB2E4 \uD0C8\uCD9C
      \uC9C0\uC810\uC774 \uB354 \uC88B\uC740 \uCE5C\uAD6C\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uD0C8\uCD9C \uC9C0\uC810\uC5D0 \uB3C4\uCC29\uD574\uB3C4 \uC989\uC2DC
      \uD0C8\uCD9C\uB418\uC9C0\uB294 \uC54A\uC2B5\uB2C8\uB2E4. \uB05D\uAE4C\uC9C0
      \uBC84\uD2F0\uC138\uC694."
    imageKey: Default
  - category: 4
    message: "\uD0C8\uCD9C \uCE74\uC6B4\uD2B8\uB2E4\uC6B4 \uC911\uC5D0\uB294 \uC8FC\uBCC0\uC744
      \uD655\uC778\uD558\uC138\uC694. \uB9C8\uC9C0\uB9C9 15\uCD08\uAC00 \uC81C\uC77C
      \uAE41\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uC870\uAC74\uBD80 \uD0C8\uCD9C \uC9C0\uC810\uC740 \uD2B9\uC815 \uC544\uC774\uD15C\uC774\uB098
      \uD018\uC2A4\uD2B8 \uC870\uAC74\uC774 \uD544\uC694\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uB808\uC774\uB4DC\uB294 \uD30C\uBC0D\uBCF4\uB2E4 \uD0C8\uCD9C\uC774
      \uC911\uC694\uD569\uB2C8\uB2E4. \uC8FD\uC740 \uC0AC\uB78C\uC758 \uC778\uBCA4\uD1A0\uB9AC\uB294
      \uD1B5\uACC4\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uD0C8\uCD9C\uC5D0 \uC131\uACF5\uD558\uBA74 \uC544\uC774\uD15C\uC740
      \uBCF4\uC0C1\uC774 \uB429\uB2C8\uB2E4. \uC2E4\uD328\uD558\uBA74 \uBC30\uACBD
      \uC124\uC815\uC774 \uB429\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uC695\uC2EC\uB0B4\uC11C \uD55C \uC0C1\uC790 \uB354 \uC5F4\uB2E4\uAC00
      \uBAA8\uB4E0 \uC0C1\uC790\uB97C \uC783\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uC0B4\uC544 \uB3CC\uC544\uC624\uBA74 \uC131\uC7A5\uD569\uB2C8\uB2E4.
      \uC8FD\uC5B4 \uB3CC\uC544\uC624\uBA74 \uAD50\uD6C8\uB9CC \uB0A8\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uC740\uC2E0\uCC98 \uC2DC\uC124\uC744 \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uBA74
      \uC0DD\uC874\uC5D0 \uD544\uC694\uD55C \uBB3C\uD488 \uC81C\uC791\uACFC \uC0DD\uC874
      \uB2A5\uB825\uC774 \uAC15\uD654\uB429\uB2C8\uB2E4."
    imageKey: Hideout
  - category: 3
    message: "\uC758\uB8CC\uC2DC\uC124\uC744 \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uBA74
      \uCD5C\uB300 \uCCB4\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4. \uB35C \uC8FD\uB294
      \uAC74 \uC544\uB2C8\uC9C0\uB9CC, \uC870\uAE08 \uB354 \uBC84\uD301\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uC758\uB8CC\uC2DC\uC124\uC740 \uCD5C\uB300 \uCCB4\uB825\uC744 \uC62C\uB824\uC90D\uB2C8\uB2E4.
      \uCE58\uB8CC\uBCF4\uB2E4 \uC88B\uC740 \uAC74 \uC548 \uB9DE\uB294 \uAC70\uC9C0\uB9CC,
      \uADF8\uAC74 \uC5B4\uB835\uC2B5\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uC758\uB8CC\uC2DC\uC124 \uB808\uBCA8\uC774 \uC624\uB974\uBA74 \uC0DD\uC874\uB825\uC774
      \uC99D\uAC00\uD569\uB2C8\uB2E4. \uCD1D\uC54C \uD55C \uBC1C \uCC28\uC774\uAC00
      \uACB0\uACFC\uB97C \uBC14\uAFC0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uC758\uB8CC\uC2DC\uC124\uC740 \uB808\uC774\uB4DC \uC804 \uBAB8 \uC0C1\uD0DC\uB97C
      \uB04C\uC5B4\uC62C\uB824\uC90D\uB2C8\uB2E4. \uC804\uC7C1\uD130\uC5D0 \uAC74\uAC15\uAC80\uC9C4\uC740
      \uC5C6\uC2B5\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uC758\uB8CC\uC2DC\uC124\uC744 \uAC15\uD654\uD558\uBA74 \uCD5C\uB300
      \uCCB4\uB825\uC774 \uC99D\uAC00\uD569\uB2C8\uB2E4. \uC900\uBE44\uB41C \uBAB8\uC740
      \uC900\uBE44\uB41C \uC7A5\uBE44\uB9CC\uD07C \uC911\uC694\uD569\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uCD5C\uB300 \uCCB4\uB825\uC774 \uB192\uC744\uC218\uB85D \uC2E4\uC218
      \uD55C \uBC88\uC744 \uB354 \uAC10\uB2F9\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
      \uB450 \uBC88\uC740 \uC7A5\uB2F4\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uC751\uAE09\uCC98\uCE58\uB294 \uC804\uC7A5\uC5D0\uC11C \uD558\uACE0,
      \uCCB4\uB825 \uAD00\uB9AC\uB294 \uC740\uC2E0\uCC98\uC5D0\uC11C \uD569\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uC758\uB8CC\uC2DC\uC124\uC740 \uC0AC\uB9DD\uC744 \uB9C9\uC544\uC8FC\uC9C4
      \uC54A\uC2B5\uB2C8\uB2E4. \uC0AC\uB9DD\uAE4C\uC9C0 \uAC00\uB294 \uC2DC\uAC04\uC744
      \uB298\uB824\uC904 \uBFD0\uC785\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uCD5C\uB300 \uCCB4\uB825 \uC99D\uAC00\uB294 \uB2E8\uC21C\uD55C \uC22B\uC790\uAC00
      \uC544\uB2D9\uB2C8\uB2E4. \uD0C8\uCD9C \uC9C1\uC804\uC758 1\uCD08\uAC00 \uB420
      \uC218\uB3C4 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: MedicalFacility
  - category: 3
    message: "\uB808\uC774\uB4DC\uC5D0\uC11C \uC0B4\uC544\uB0A8\uACE0 \uC2F6\uB2E4\uBA74
      \uCD1D\uB9CC \uCC59\uAE30\uC9C0 \uB9D0\uACE0 \uBAB8\uB3C4 \uCC59\uAE30\uC138\uC694."
    imageKey: MedicalFacility
  - category: 3
    message: "\uD5EC\uC2A4\uC7A5\uC740 \uC18C\uC9C0 \uBB34\uAC8C\uC5D0 \uC601\uD5A5\uC744
      \uC90D\uB2C8\uB2E4. \uD30C\uBC0D\uB3C4 \uADFC\uB825\uC785\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC870\uB9AC\uC2DC\uC124\uC740 \uC2A4\uD14C\uBBF8\uB108\uB3C4\uC6C0\uC744
      \uC90D\uB2C8\uB2E4. \uC804\uC7C1\uD130\uC5D0\uC11C\uB3C4 \uBC25\uC740 \uC911\uC694\uD569\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC2DC\uC124 \uC5C5\uADF8\uB808\uC774\uB4DC \uC7AC\uB8CC\uB294 \uBC84\uB9AC\uC9C0
      \uB9C8\uC138\uC694. \uC9C0\uAE08\uC740 \uC7A1\uB3D9\uC0AC\uB2C8, \uB098\uC911\uC5D4
      \uAE30\uBC18\uC2DC\uC124\uC785\uB2C8\uB2E4."
    imageKey: Hideout
  - category: 3
    message: "\uC740\uC2E0\uCC98\uB294 \uC548\uC804\uD569\uB2C8\uB2E4. \uB2E8, \uB2F9\uC2E0\uC758
      \uC815\uB9AC \uC2B5\uAD00\uAE4C\uC9C0 \uAD6C\uD574\uC8FC\uC9C4 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: Hideout
  - category: 5
    message: "\uC804\uC124 \uB4F1\uAE09 JADE\uCA29 \uD53C\uADDC\uC5B4\uB294 0.1%
      \uD655\uB960\uB85C \uB4DC\uB78D\uB429\uB2C8\uB2E4. \uBC1C\uACAC\uD588\uB2E4\uBA74
      \uC624\uB298\uC740 \uB098\uAC00\uC9C0 \uB9C8\uC138\uC694. \uC6B4 \uB2E4 \uC37C\uC2B5\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "JADE\uCA29 \uD53C\uADDC\uC5B4\uB97C \uCC3E\uC558\uB2E4\uBA74 \uBCF4\uAD00\uD558\uC138\uC694.
      \uADC0\uC5FD\uACE0, \uD76C\uADC0\uD558\uACE0, \uC774\uC0C1\uD558\uAC8C \uAC15\uD574\uC9D1\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "0.1% \uD655\uB960\uC740 \uB0AE\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC
      \uC0AC\uB78C\uC740 \uC6D0\uB798 \uB0AE\uC740 \uD655\uB960\uC5D0 \uC778\uC0DD\uC744
      \uAC81\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "JADE\uCA29 \uD53C\uADDC\uC5B4\uB294 \uB2E8\uC21C\uD55C \uC7A5\uC2DD\uD488\uC774
      \uC544\uB2D9\uB2C8\uB2E4. \uB204\uAD70\uAC00\uC758 \uC9D1\uCC29\uC774 \uC2A4\uD0EF\uC73C\uB85C
      \uD658\uC0B0\uB41C \uACB0\uACFC\uC785\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "\uC804\uC124\uC740 \uCD1D\uAD6C\uC5D0\uC11C\uB9CC \uD0C4\uC0DD\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uAC00\uB054 \uD53C\uADDC\uC5B4 \uC120\uBC18\uC5D0\uC11C\uB3C4
      \uB098\uC635\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "JADE\uCA29 \uD53C\uADDC\uC5B4\uB97C \uBC1C\uACAC\uD558\uBA74 \uD300\uC6D0\uC5D0\uAC8C
      \uB9D0\uD558\uC9C0 \uB9C8\uC138\uC694. \uC6B0\uC815\uC740 \uB4DC\uB78D\uB960\uBCF4\uB2E4
      \uB0AE\uC744 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "\uC778\uC2F8 \uB9C8\uC774\uD06C\uB97C \uBC1C\uACAC\uD588\uB2E4\uBA74
      \uC870\uC6A9\uD788 \uCC59\uAE30\uC138\uC694. \uC2DC\uB044\uB7EC\uC6B4 \uC0AC\uB78C\uC77C\uC218\uB85D
      \uBE44\uC2F8\uAC8C \uD314\uB9BD\uB2C8\uB2E4."
    imageKey: VolkimMicrophone
  - category: 5
    message: "\uC778\uC2F8 \uB9C8\uC774\uD06C\uB294 \uC804\uC7C1\uD130\uC5D0\uC11C\uB3C4
      \uC874\uC7AC\uAC10\uC744 \uC783\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uBB38\uC81C\uB294
      \uC801\uB3C4 \uB4E4\uC744 \uC218 \uC788\uB2E4\uB294 \uAC81\uB2C8\uB2E4."
    imageKey: VolkimMicrophone
  - category: 5
    message: "\uB9D0\uC774 \uB9CE\uC740 \uC7A5\uBE44\uB294 \uBCF4\uD1B5 \uBE44\uC309\uB2C8\uB2E4.
      \uC778\uC2F8 \uB9C8\uC774\uD06C\uB3C4 \uC608\uC678\uB294 \uC544\uB2D9\uB2C8\uB2E4."
    imageKey: VolkimMicrophone
  - category: 5
    message: "\uB9C8\uC774\uD06C\uB97C \uB4E4\uC5C8\uB2E4\uACE0 \uC18C\uD1B5\uC774
      \uC88B\uC544\uC9C0\uB294 \uAC74 \uC544\uB2D9\uB2C8\uB2E4. \uADF8\uB798\uB3C4
      \uAC00\uACA9\uC740 \uC88B\uC2B5\uB2C8\uB2E4."
    imageKey: VolkimMicrophone
  - category: 5
    message: "\uC778\uC2F8 \uB9C8\uC774\uD06C\uB294 \uADC0\uC911\uD488\uC785\uB2C8\uB2E4.
      \uC0AC\uC6A9\uBC95\uC740 \uBAA8\uB985\uB2C8\uB2E4. \uC77C\uB2E8 \uCC59\uAE30\uC138\uC694."
    imageKey: VolkimMicrophone
  - category: 5
    message: "\uD559\uC2B5\uC758 \uC548\uACBD\uC744 \uCC3E\uC558\uB2E4\uBA74 \uCC29\uC6A9\uC790\uC758
      \uC9C0\uB2A5\uC774 \uC624\uB978\uB2E4\uB294 \uC18C\uBB38\uC774 \uC788\uC2B5\uB2C8\uB2E4.
      \uD655\uC778\uB41C \uAC74 \uAC00\uACA9\uBFD0\uC785\uB2C8\uB2E4."
    imageKey: StudyGlasses
  - category: 5
    message: "\uC548\uACBD\uC740 \uC2DC\uC57C\uB97C \uBC1D\uD600\uC90D\uB2C8\uB2E4.
      \uD310\uB2E8\uB825\uAE4C\uC9C0 \uBC1D\uD600\uC8FC\uC9C4 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: StudyGlasses
  - category: 5
    message: "\uD559\uC2B5\uC758 \uC548\uACBD\uC740 \uADC0\uC911\uD488\uC785\uB2C8\uB2E4.
      \uACF5\uBD80\uB294 \uC548 \uD574\uB3C4 \uB3C8\uC740 \uB429\uB2C8\uB2E4."
    imageKey: StudyGlasses
  - category: 5
    message: "\uC88B\uC740 \uC548\uACBD\uC740 \uBA3C \uACF3\uC744 \uBCF4\uAC8C \uD574\uC90D\uB2C8\uB2E4.
      \uD0C8\uCD9C \uC9C0\uC810\uB3C4 \uAC19\uC774 \uBCF4\uC774\uBA74 \uC88B\uACA0\uAD70\uC694."
    imageKey: StudyGlasses
  - category: 5
    message: "\uD559\uC2B5\uC758 \uC548\uACBD\uC744 \uC8FC\uC6E0\uB2E4\uBA74 \uCC45\uC0C1\uBCF4\uB2E4
      \uAC00\uBC29\uC5D0 \uB123\uC73C\uC138\uC694. \uC5EC\uAE34 \uB3C4\uC11C\uAD00\uC774
      \uC544\uB2D9\uB2C8\uB2E4."
    imageKey: StudyGlasses
  - category: 5
    message: "\uB450\uADFC\uB450\uADFC \uC758\uC874\uC131\uC740 \uCC45\uC785\uB2C8\uB2E4.
      \uC77D\uC73C\uBA74 \uAC15\uD574\uC9C8 \uC218\uB3C4 \uC788\uACE0, \uD504\uB85C\uC81D\uD2B8\uAC00
      \uD130\uC9C8 \uC218\uB3C4 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: DependencyBook
  - category: 5
    message: "\uC758\uC874\uC131\uC740 \uB0AE\uC744\uC218\uB85D \uC88B\uC2B5\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uC774 \uCC45\uC740 \uB192\uC744\uC218\uB85D \uC218\uC0C1\uD569\uB2C8\uB2E4."
    imageKey: DependencyBook
  - category: 5
    message: "\uB450\uADFC\uB450\uADFC \uC758\uC874\uC131\uC744 \uBC1C\uACAC\uD588\uB2E4\uBA74
      \uC870\uC2EC\uD558\uC138\uC694. \uD55C \uBC88 \uC5EE\uC774\uBA74 \uBE60\uC838\uB098\uC624\uAE30
      \uC5B4\uB835\uC2B5\uB2C8\uB2E4."
    imageKey: DependencyBook
  - category: 5
    message: "\uC774 \uCC45\uC740 \uC81C\uC791 \uC7AC\uB8CC\uAC00 \uC544\uB2D0 \uC218\uB3C4
      \uC788\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uAC1C\uBC1C\uC790\uC758 \uC2EC\uBC15\uC218\uB294
      \uC62C\uB9BD\uB2C8\uB2E4."
    imageKey: DependencyBook
  - category: 5
    message: "\uB450\uADFC\uB450\uADFC \uC758\uC874\uC131\uC740 \uC804\uC7C1\uBCF4\uB2E4
      \uBB34\uC12D\uB2E4\uB294 \uB9D0\uC774 \uC788\uC2B5\uB2C8\uB2E4. \uD2B9\uD788
      \uB9C8\uAC10 \uC804\uB0A0\uC5D0."
    imageKey: DependencyBook
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB294 \uC544\uC774\uD15C\uC73C\uB85C
      \uC874\uC7AC\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uB85C\uB529
      \uD654\uBA74\uC5D0\uC11C\uB294 \uC874\uC7AC\uAC10\uC744 \uC8FC\uC7A5\uD569\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uAE30\uB85D\uC0C1 \uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB294 \uB4DC\uB78D\uB418\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uBAA9\uACA9\uB2F4\uB9CC \uB0A8\uC544 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB97C \uBD24\uB2E4\uBA74 \uC815\uC0C1\uC785\uB2C8\uB2E4.
      \uC544\uC9C1 \uB85C\uB529 \uC911\uC774\uB2C8\uAE4C\uC694."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB294 \uC778\uBCA4\uD1A0\uB9AC\uC5D0
      \uB4E4\uC5B4\uAC00\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4. \uB300\uC2E0 \uAE30\uC5B5\uC5D0
      \uB0A8\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uB204\uAD70\uAC00\uB294 \uC804\uC124 \uC544\uC774\uD15C\uC744 \uCC3E\uACE0,
      \uB204\uAD70\uAC00\uB294 \uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB97C \uBD05\uB2C8\uB2E4.
      \uB458 \uB2E4 \uC27D\uAC8C \uC124\uBA85\uB418\uC9C4 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB294 \uD310\uB9E4\uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uC560\uCD08\uC5D0 \uC18C\uC720\uD55C \uC801\uB3C4 \uC5C6\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uAC00 \uBCF4\uC778\uB2E4\uBA74 \uAC8C\uC784\uC740
      \uC544\uC9C1 \uBA48\uCD94\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4. \uB2F9\uC2E0\uC758
      \uC815\uC2E0\uB825\uC740 \uBAA8\uB974\uACA0\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uAC1C\uBC1C\uD300\uC740 \uC2B9\uCA29 \uD53C\uADDC\uC5B4\uC758 \uC874\uC7AC\uB97C
      \uBD80\uC815\uD558\uC9C0\uB3C4, \uC778\uC815\uD558\uC9C0\uB3C4 \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB294 \uC2A4\uD0EF\uC744 \uC62C\uB824\uC8FC\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uBD84\uC704\uAE30\uB294 \uC62C\uB824\uC90D\uB2C8\uB2E4."
    imageKey: SeungwooFigure
  - category: 5
    message: "\uB85C\uB529\uC774 \uAE38\uB2E4\uBA74 \uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB97C
      \uAC10\uC0C1\uD558\uC138\uC694. \uADF8\uAC83\uB3C4 \uCF58\uD150\uCE20\uC785\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 6
    message: "\uC0AC\uB9DD\uD558\uBA74 \uAC00\uBC29\uC744 \uC783\uC2B5\uB2C8\uB2E4.
      \uC544\uB9C8 \uB204\uAD70\uAC00 \uAC00\uC838\uAC14\uC744 \uAC81\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC758\uB3C4\uAC00 \uBA85\uD655\uD574\uC11C \uD560 \uB9D0\uC774 \uC5C6\uB124\uC694.
      \uADF8\uB798\uC11C \uC408\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC774 \uC9C0\uC5ED\uC740 \uC548\uC804\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.
      \uC548\uC804\uD588\uB2E4\uBA74 \uAC8C\uC784\uC774 \uC544\uB2C8\uC5C8\uACA0\uC8E0."
    imageKey: Default
  - category: 6
    message: "\uCD1D\uC54C\uC740 \uADC0\uD569\uB2C8\uB2E4. \uC801\uC5D0\uAC8C \uAE30\uBD80\uD558\uC9C0
      \uB9C8\uC138\uC694."
    imageKey: Default
  - category: 6
    message: "\uC624\uB298\uC758 \uAD50\uD6C8: \uC0B4\uC544\uB0A8\uC740 \uC0AC\uB78C\uC774
      \uB8E8\uD305\uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uBC29\uC2EC\uC740 \uBB34\uB8CC\uC785\uB2C8\uB2E4. \uB300\uAC00\uB294
      \uBE44\uC309\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uD300\uC6D0\uC740 \uC790\uC0B0\uC785\uB2C8\uB2E4. \uAC00\uB054 \uC6C0\uC9C1\uC774\uB294
      \uAC00\uBC29\uC774\uAE30\uB3C4 \uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC801\uC774 \uC57D\uD574 \uBCF4\uC5EC\uB3C4 \uBC29\uC2EC\uD558\uC9C0
      \uB9C8\uC138\uC694. \uB2F9\uC2E0\uB3C4 \uADF8\uB807\uAC8C \uBCF4\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC8FD\uC74C\uC740 \uBE60\uB974\uACE0, \uB85C\uB529\uC740 \uC0C1\uB300\uC801\uC73C\uB85C
      \uAE41\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC88B\uC740 \uD310\uB2E8\uC740 \uC0DD\uC874\uC728\uC744 \uC62C\uB9BD\uB2C8\uB2E4.
      \uB098\uC05C \uD310\uB2E8\uC740 \uCD94\uC5B5\uC744 \uB9CC\uB4ED\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC804\uC7C1\uD130\uC5D0\uC11C \uAC00\uC7A5 \uC704\uD5D8\uD55C \uAC74
      \uC801\uC774 \uC544\uB2D0 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uC695\uC2EC\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uAC00\uBC29\uC774 \uBB34\uAC70\uC6CC\uC84C\uB2E4\uBA74 \uB9C8\uC74C\uB3C4
      \uBB34\uAC70\uC6CC\uC9C8 \uC900\uBE44\uB97C \uD558\uC138\uC694."
    imageKey: Default
  - category: 6
    message: "\uD1F4\uAC01\uC740 \uD328\uBC30\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uB2E4\uC74C
      \uD310 \uC785\uC7A5\uAD8C\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 6
    message: "\uC801\uC744 \uBAA8\uB450 \uC7A1\uC744 \uD544\uC694\uB294 \uC5C6\uC2B5\uB2C8\uB2E4.
      \uC0B4\uC544\uC11C \uB098\uAC00\uBA74 \uB429\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uC0B4\uC544\uC11C \uB098\uAC00\uC57C \uC804\uB9AC\uD488\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uCD1D\uC54C\uBCF4\uB2E4 \uD0C8\uCD9C \uC2DC\uAC04\uC774 \uB354 \uC18C\uC911\uD560
      \uB54C\uAC00 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uAC00\uBC29 \uC815\uB9AC\uB294 \uC804\uD22C \uC900\uBE44\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uD76C\uADC0\uD55C \uAC74 \uB300\uCCB4\uB85C \uBB34\uAC81\uAC70\uB098
      \uC704\uD5D8\uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 0
    message: "\uAD6C\uB974\uAE30\uB294 \uD68C\uD53C\uC6A9\uC785\uB2C8\uB2E4. \uAD00\uAD11\uC6A9\uC774
      \uC544\uB2D9\uB2C8\uB2E4."
    imageKey: Default
  - category: 1
    message: "\uC801\uC758 \uBA38\uB9AC\uB97C \uB178\uB9AC\uC138\uC694. \uB0B4 \uBA38\uB9AC\uB294
      \uC228\uAE30\uC138\uC694."
    imageKey: Default
  - category: 1
    message: "\uC88B\uC740 \uC7A5\uBE44\uB294 \uC0DD\uC874\uC728\uC744 \uC62C\uB9BD\uB2C8\uB2E4.
      \uACFC\uC2E0\uB3C4 \uAC19\uC774 \uC62C\uB9BD\uB2C8\uB2E4."
    imageKey: Default
  - category: 4
    message: "\uD0C8\uCD9C \uC9C0\uC810\uC740 \uBAA9\uC801\uC9C0\uC774\uC9C0 \uC548\uC804\uC9C0\uB300\uAC00
      \uC544\uB2D9\uB2C8\uB2E4."
    imageKey: Default
  - category: 2
    message: "\uD55C \uCE78\uC9DC\uB9AC \uC544\uC774\uD15C\uB3C4 \uC778\uC0DD\uC744
      \uBC14\uAFC0 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uC624\uB298\uC758 \uD30C\uBC0D\uC740 \uB0B4\uC77C\uC758 \uC5C5\uADF8\uB808\uC774\uB4DC\uC785\uB2C8\uB2E4."
    imageKey: Hideout
  - category: 5
    message: "0.1%\uB294 \uB0AE\uC2B5\uB2C8\uB2E4. \uADF8\uB798\uC11C \uC804\uC124\uC785\uB2C8\uB2E4."
    imageKey: JadeFigure
  - category: 5
    message: "\uC2B9\uCA29 \uD53C\uADDC\uC5B4\uB294 \uC874\uC7AC\uD558\uC9C0 \uC54A\uC2B5\uB2C8\uB2E4.
      \uC544\uB9C8\uB3C4\uC694."
    imageKey: SeungwooFigure
  - category: 3
    message: "\uD5EC\uC2A4\uC7A5\uC744 \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uBA74
      \uC18C\uC9C0 \uBB34\uAC8C \uCD5C\uB300\uCE58\uAC00 \uC99D\uAC00\uD569\uB2C8\uB2E4.
      \uB354 \uB9CE\uC774 \uB4E4 \uC218 \uC788\uB2E4\uB294 \uAC74, \uB354 \uB9CE\uC774
      \uC783\uC744 \uC218\uB3C4 \uC788\uB2E4\uB294 \uB73B\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uD5EC\uC2A4\uC7A5\uC740 \uC18C\uC9C0 \uBB34\uAC8C\uB97C \uB298\uB824\uC90D\uB2C8\uB2E4.
      \uC695\uC2EC\uC744 \uAC10\uB2F9\uD558\uB824\uBA74 \uADFC\uB825\uBD80\uD130
      \uD0A4\uC6B0\uC138\uC694."
    imageKey: Kitchen
  - category: 3
    message: "\uD5EC\uC2A4\uC7A5 \uB808\uBCA8\uC774 \uC624\uB974\uBA74 \uB354 \uB9CE\uC740
      \uC7A5\uBE44\uB97C \uB4E4 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \uBB3C\uB860 \uC0B4\uC544\uC11C
      \uB4E4\uACE0 \uB098\uC640\uC57C \uD569\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uD30C\uBC0D\uC740 \uC190\uC774 \uC544\uB2C8\uB77C \uD5C8\uB9AC\uB85C
      \uD558\uB294 \uC77C\uC785\uB2C8\uB2E4. \uD5EC\uC2A4\uC7A5\uC744 \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uC138\uC694."
    imageKey: Kitchen
  - category: 3
    message: "\uC18C\uC9C0 \uBB34\uAC8C\uAC00 \uB298\uC5B4\uB098\uBA74 \uC120\uD0DD\uC9C0\uAC00
      \uB298\uC5B4\uB0A9\uB2C8\uB2E4. \uD310\uB2E8\uB825\uAE4C\uC9C0 \uB298\uC5B4\uB098\uC9C4
      \uC54A\uC2B5\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC870\uB9AC \uC2DC\uC124\uC744 \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uBA74
      \uCD5C\uB300 \uC2A4\uD0DC\uBBF8\uB098\uAC00 \uC99D\uAC00\uD569\uB2C8\uB2E4.
      \uC798 \uBA39\uC5B4\uC57C \uC624\uB798 \uB3C4\uB9DD\uCE69\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC804\uC7C1\uD130\uC5D0\uC11C\uB3C4 \uBC25\uC740 \uC911\uC694\uD569\uB2C8\uB2E4.
      \uC870\uB9AC \uC2DC\uC124\uC740 \uB2E4\uC74C \uB808\uC774\uB4DC\uC758 \uCCB4\uB825\uC744
      \uC900\uBE44\uD569\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC870\uB9AC \uC2DC\uC124 \uB808\uBCA8\uC774 \uC624\uB974\uBA74 \uC2A4\uD0DC\uBBF8\uB098\uAC00
      \uC99D\uAC00\uD569\uB2C8\uB2E4. \uAD76\uC8FC\uB9B0 \uC0DD\uC874\uC790\uB294
      \uC624\uB798 \uB6F0\uC9C0 \uBABB\uD569\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC88B\uC740 \uC2DD\uC0AC\uB294 \uC88B\uC740 \uD0C4\uCC3D\uB9CC\uD07C
      \uC911\uC694\uD569\uB2C8\uB2E4. \uB458 \uB2E4 \uC5C6\uC73C\uBA74 \uC624\uB798
      \uBC84\uD2F0\uAE30 \uC5B4\uB835\uC2B5\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uB2EC\uB9AC\uACE0, \uAD6C\uB974\uACE0, \uC0B4\uC544\uB0A8\uC73C\uB824\uBA74
      \uBA3C\uC800 \uBA39\uC5B4\uC57C \uD569\uB2C8\uB2E4."
    imageKey: Kitchen
  - category: 3
    message: "\uC791\uC5C5\uB300 \uB808\uBCA8\uC774 \uC624\uB974\uBA74 \uB354 \uB192\uC740
      \uB4F1\uAE09\uC758 \uC544\uC774\uD15C\uC744 \uC81C\uC791\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uC88B\uC740 \uC7A5\uBE44\uB294 \uC6B4\uC73C\uB85C \uC5BB\uC744 \uC218\uB3C4
      \uC788\uC9C0\uB9CC, \uC791\uC5C5\uB300\uC5D0\uC11C\uB294 \uACC4\uD68D\uC73C\uB85C
      \uB9CC\uB4ED\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uC791\uC5C5\uB300\uB97C \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uBA74
      \uC81C\uC791 \uAC00\uB2A5\uD55C \uC7A5\uBE44 \uB4F1\uAE09\uC774 \uD655\uC7A5\uB429\uB2C8\uB2E4.
      \uCD1D\uC54C\uB3C4 \uC900\uBE44\uB41C \uC0AC\uB78C\uC744 \uC88B\uC544\uD569\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uB808\uC774\uB4DC\uC5D0\uC11C \uC8FC\uC6B4 \uC7A1\uB3D9\uC0AC\uB2C8\uB294
      \uC791\uC5C5\uB300 \uC55E\uC5D0\uC11C \uC7A5\uBE44\uAC00 \uB429\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uC791\uC5C5\uB300\uB294 \uD3D0\uD488\uC744 \uC0DD\uC874 \uC218\uB2E8\uC73C\uB85C
      \uBC14\uAFC9\uB2C8\uB2E4. \uAE30\uC801\uC740 \uC544\uB2C8\uACE0 \uC81C\uC791\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uCE68\uC2E4\uC744 \uC5C5\uADF8\uB808\uC774\uB4DC\uD558\uBA74 \uCD5C\uB300
      \uC2A4\uD0DC\uBBF8\uB098\uAC00 \uC99D\uAC00\uD569\uB2C8\uB2E4. \uC7A0\uB3C4
      \uC0DD\uC874 \uC804\uB7B5\uC785\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uC798 \uC26C\uB294 \uC0DD\uC874\uC790\uAC00 \uB354 \uC624\uB798 \uB701\uB2C8\uB2E4.
      \uCE68\uC2E4 \uC5C5\uADF8\uB808\uC774\uB4DC\uB97C \uBB34\uC2DC\uD558\uC9C0
      \uB9C8\uC138\uC694."
    imageKey: Default
  - category: 3
    message: "\uCE68\uC2E4 \uB808\uBCA8\uC774 \uC624\uB974\uBA74 \uC2A4\uD0DC\uBBF8\uB098
      \uC5EC\uC720\uAC00 \uB298\uC5B4\uB0A9\uB2C8\uB2E4. \uD53C\uB85C\uD55C \uBAB8\uC740
      \uC804\uC7A5\uC5D0\uC11C \uC624\uB798 \uBABB \uBC84\uD301\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uCE68\uC2E4\uC740 \uC804\uD22C \uC2DC\uC124\uC774 \uC544\uB2D9\uB2C8\uB2E4.
      \uD558\uC9C0\uB9CC \uB2E4\uC74C \uC804\uD22C\uB97C \uBC84\uD2F0\uAC8C \uB9CC\uB4ED\uB2C8\uB2E4."
    imageKey: Default
  - category: 3
    message: "\uD734\uC2DD\uC740 \uC0AC\uCE58\uAC00 \uC544\uB2D9\uB2C8\uB2E4. \uB2E4\uC74C
      \uB808\uC774\uB4DC\uC758 \uBCF4\uD5D8 \uAC19\uC740 \uAC81\uB2C8\uB2E4."
    imageKey: Default
  - category: 5
    message: "\uC81C\uC774\uB4DC\uB294 \uC2B9\uCA29\uC744 \uBB34\uC2DC\uD558\uB294
      \uCC99\uD569\uB2C8\uB2E4. \uD558\uC9C0\uB9CC \uB4DC\uB78D \uB85C\uADF8\uB294
      \uB204\uAD6C\uBCF4\uB2E4 \uBA3C\uC800 \uD655\uC778\uD569\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC\uB97C \uC774\uAE38 \uC218 \uC5C6\uB2E4\uACE0
      \uB9D0\uD569\uB2C8\uB2E4. \uC774\uC0C1\uD558\uAC8C \uB9E4\uBC88 \uB530\uB77C\uAC11\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uC640 \uC2B9\uCA29\uC774 \uAC19\uC740 \uD654\uBA74\uC5D0
      \uBCF4\uC778\uB2E4\uBA74 \uC870\uC2EC\uD558\uC138\uC694. \uB85C\uB529\uBCF4\uB2E4
      \uAC10\uC815\uC120\uC774 \uB354 \uBB34\uAC81\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC\uAC00 \uC2EB\uB2E4\uACE0 \uD588\uC2B5\uB2C8\uB2E4.
      \uADF8\uB798\uC11C \uC624\uB298\uB3C4 \uAC00\uC7A5 \uBA3C\uC800 \uCC3E\uACE0
      \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uB294 \uC2B9\uCA29\uC744 \uADC0\uCC2E\uC544\uD569\uB2C8\uB2E4.
      \uB2E8, \uB204\uAC00 \uBA3C\uC800 \uAC74\uB4DC\uB9AC\uBA74 \uC774\uC57C\uAE30\uAC00
      \uB2EC\uB77C\uC9D1\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uACFC \uC81C\uC774\uB4DC\uB294 \uC0AC\uC774\uAC00 \uB098\uC069\uB2C8\uB2E4.
      \uC815\uD655\uD788\uB294 \uB0A8\uC774 \uBCF4\uBA74 \uC0AC\uC774\uAC00 \uC88B\uC544
      \uBCF4\uC77C \uB9CC\uD07C \uB098\uC069\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC \uD53C\uADDC\uC5B4\uB97C \uD68D\uB4DD\uD588\uB2E4\uBA74
      \uC2B9\uCA29\uC5D0\uAC8C \uC790\uB791\uD558\uC9C0 \uB9C8\uC138\uC694. \uBC18\uC751\uC774
      \uADC0\uCC2E\uC544\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC \uD53C\uADDC\uC5B4\uB97C \uD544\uC694
      \uC5C6\uB2E4\uACE0 \uB9D0\uD588\uC2B5\uB2C8\uB2E4. \uC544\uC9C1 \uBC84\uB9AC\uC9C0\uB294
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uB294 \uC2B9\uCA29\uC758 \uC791\uC804\uC744 \uBE44\uC6C3\uC2B5\uB2C8\uB2E4.
      \uBB38\uC81C\uB294 \uADF8 \uC791\uC804\uC774 \uAC00\uB054 \uD1B5\uD55C\uB2E4\uB294
      \uAC81\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uACFC \uC81C\uC774\uB4DC\uAC00 \uD568\uAED8 \uC788\uB2E4\uBA74,
      \uC804\uD22C\uBCF4\uB2E4 \uB9D0\uC2F8\uC6C0\uC774 \uBA3C\uC800 \uC2DC\uC791\uB420
      \uC218 \uC788\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uB531\uD788 \uAC71\uC815\uD55C \uAC74 \uC544\uB2C8\uAC70\uB4E0?\u201D
      \uC81C\uC774\uB4DC\uB294 \uADF8\uB807\uAC8C \uB9D0\uD558\uACE0 \uD0C8\uCD9C
      \uC9C0\uC810\uC744 \uBA3C\uC800 \uD655\uC778\uD588\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uD765, \uB124\uAC00 \uC8FD\uC73C\uBA74 \uADC0\uCC2E\uC544\uC9C8
      \uBFD0\uC774\uC57C.\u201D \uC81C\uC774\uB4DC\uB294 \uD68C\uBCF5 \uC544\uC774\uD15C\uC744
      \uAC74\uB138\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uCC29\uAC01\uD558\uC9C0 \uB9C8. \uC774\uBC88\uB9CC \uB3C4\uC640\uC8FC\uB294
      \uAC70\uB2C8\uAE4C.\u201D \uC81C\uC774\uB4DC\uC758 \uC774\uBC88\uC740 \uBC8C\uC368
      \uC5F4 \uBC88\uC9F8\uC785\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uC81C\uC774\uB4DC \uC5C6\uC5B4\uB3C4 \uD560 \uC218 \uC788\uAC70\uB4E0?\u201D
      \uC2B9\uCA29\uC740 \uADF8\uB807\uAC8C \uB9D0\uD558\uACE0 3\uCD08 \uB4A4 \uB3C4\uC6C0\uC744
      \uC694\uCCAD\uD588\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uC774\uAC74 \uC804\uB7B5\uC801 \uB3D9\uD589\uC774\uC57C.\u201D
      \uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC \uB4A4\uC5D0 \uC228\uC5B4 \uB9D0\uD588\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uB204\uAC00 \uB124 \uAC71\uC815\uC744 \uD55C\uB2E4\uACE0 \uD588\uC5B4?\u201D
      \uC81C\uC774\uB4DC\uB294 \uC774\uBBF8 \uD0C4\uCC3D\uC744 \uAC08\uC544 \uB07C\uC6B0\uACE0
      \uC788\uC5C8\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uB108 \uB54C\uBB38\uC774 \uC544\uB2C8\uC57C. \uC804\uB9AC\uD488
      \uB54C\uBB38\uC774\uC57C.\u201D \uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC \uCABD\uC73C\uB85C
      \uB2EC\uB838\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uAC19\uC774 \uAC00\uC790\uB294 \uB9D0\uC740 \uC548 \uD588\uC5B4.\u201D
      \uC81C\uC774\uB4DC\uB294 \uC2B9\uCA29\uC774 \uB530\uB77C\uC624\uB294 \uAC78
      \uB9C9\uC9C0 \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uC774\uBC88\uC5D4 \uB0B4\uAC00 \uAD6C\uD574\uC900 \uAC70\uB2E4?\u201D
      \uC2B9\uCA29\uC740 \uBC29\uAE08 \uC81C\uC774\uB4DC\uC5D0\uAC8C \uAD6C\uC870\uBC1B\uC558\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\u201C\uD765, \uACE0\uB9D9\uB2E4\uB294 \uB9D0\uC740 \uB410\uC5B4.\u201D
      \uC81C\uC774\uB4DC\uB294 \uB4E4\uB9AC\uC9C0 \uC54A\uC744 \uB9CC\uD07C \uC791\uAC8C
      \uC6C3\uC5C8\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uB294 \uC2B9\uCA29\uC744 \uC2E0\uB8B0\uD558\uC9C0
      \uC54A\uC2B5\uB2C8\uB2E4. \uADF8\uB798\uB3C4 \uAC19\uC740 \uD0C8\uCD9C \uC9C0\uC810\uC744
      \uD5A5\uD569\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC\uB97C \uB77C\uC774\uBC8C\uC774\uB77C
      \uBD80\uB985\uB2C8\uB2E4. \uC81C\uC774\uB4DC\uB294 \uC544\uC9C1 \uC778\uC815\uD558\uC9C0
      \uC54A\uC558\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC560\uC99D \uAD00\uACC4\uC758 \uB3D9\uB8CC\uC640 \uB808\uC774\uB4DC\uC5D0
      \uB4E4\uC5B4\uAC08 \uB550, \uCD1D\uC54C\uBCF4\uB2E4 \uB300\uD654 \uAC70\uB9AC\uB97C
      \uC870\uC2EC\uD558\uC138\uC694."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uC640 \uC2B9\uCA29\uC740 \uC790\uC8FC \uB2E4\uD23D\uB2C8\uB2E4.
      \uB2E4\uB9CC \uC801\uC774 \uB07C\uC5B4\uB4E4\uBA74 \uC6B0\uC120\uC21C\uC704\uAC00
      \uBC14\uB01D\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC\uC758 \uC794\uC18C\uB9AC\uAC00
      \uC2EB\uB2E4\uACE0 \uD569\uB2C8\uB2E4. \uC774\uC0C1\uD558\uAC8C \uC0DD\uC874\uC728\uC740
      \uC62C\uB77C\uAC11\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uC758 \uB3C5\uC124\uC740 \uBC29\uC5B4\uAD6C\uBCF4\uB2E4
      \uC587\uC9C0\uB9CC, \uC2B9\uCA29\uC5D0\uAC8C\uB294 \uB354 \uC544\uD504\uAC8C
      \uB4E4\uC5B4\uAC11\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uACFC \uC81C\uC774\uB4DC\uB294 \uC11C\uB85C\uB97C \uBBFF\uC9C0
      \uC54A\uB294\uB2E4\uACE0 \uB9D0\uD569\uB2C8\uB2E4. \uC804\uD22C \uAE30\uB85D\uC740
      \uB2E4\uB974\uAC8C \uB9D0\uD569\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uB458\uC774 \uC2F8\uC6B0\uAE30 \uC2DC\uC791\uD588\uB2E4\uBA74 \uC544\uC9C1
      \uC548\uC804\uD55C \uAC81\uB2C8\uB2E4. \uC9C4\uC9DC \uC704\uD5D8\uD558\uBA74
      \uB9D0\uC218\uAC00 \uC904\uC5B4\uB4ED\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uB294 \uC2B9\uCA29\uC744 \uBC84\uB9AC\uACE0 \uAC04
      \uC801\uC774 \uC5C6\uC2B5\uB2C8\uB2E4. \uC55E\uC11C \uAC14\uC744 \uBFD0\uC785\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC740 \uC81C\uC774\uB4DC\uC5D0\uAC8C \uC9C0\uC9C0 \uC54A\uC558\uB2E4\uACE0
      \uC8FC\uC7A5\uD569\uB2C8\uB2E4. \uACB0\uACFC\uCC3D\uC740 \uC870\uC6A9\uD788
      \uBC18\uBC15\uD569\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC: \u201C\uBC14\uBCF4\uC57C, \uADF8\uCABD\uC740 \uC704\uD5D8\uD558\uC796\uC544.\u201D
      \uC2B9\uCA29\uC740 \uC774\uBBF8 \uADF8\uCABD\uC73C\uB85C \uAC14\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29: \u201C\uACC4\uD68D\uB300\uB85C\uC57C.\u201D \uC81C\uC774\uB4DC:
      \u201C\uADF8 \uB9D0 \uD55C \uB4A4\uB85C \uC131\uACF5\uD55C \uC801 \uC5C6\uC796\uC544.\u201D"
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC: \u201C\uC815\uB9D0 \uC190\uC774 \uB9CE\uC774 \uAC00\uB124.\u201D
      \uC2B9\uCA29\uC740 \uADF8 \uB9D0\uC744 \uCE6D\uCC2C\uC73C\uB85C \uBC1B\uC544\uB4E4\uC600\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29: \u201C\uB098 \uC5C6\uC73C\uBA74 \uC2EC\uC2EC\uD558\uC796\uC544?\u201D
      \uC81C\uC774\uB4DC\uB294 \uC7AC\uC7A5\uC804\uC73C\uB85C \uB300\uB2F5\uD588\uC2B5\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC: \u201C\uC774\uBC88\uB9CC\uC774\uC57C.\u201D \uC2DC\uC2A4\uD15C\uC740
      \uD574\uB2F9 \uB300\uC0AC\uB97C \uBC18\uBCF5 \uC7AC\uC0DD \uC911\uC785\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29: \u201C\uC774\uAC74 \uC6B4\uBA85\uC774\uC57C.\u201D \uC81C\uC774\uB4DC:
      \u201C\uADF8\uAC74 \uB124 \uCC29\uAC01\uC774\uC57C.\u201D"
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC81C\uC774\uB4DC\uAC00 \uD654\uB09C \uAC83\uCC98\uB7FC \uBCF4\uC778\uB2E4\uBA74
      \uC815\uC0C1\uC785\uB2C8\uB2E4. \uC2B9\uCA29\uC774 \uADFC\uCC98\uC5D0 \uC788\uB2E4\uB294
      \uB73B\uC785\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
  - category: 5
    message: "\uC2B9\uCA29\uC774 \uC870\uC6A9\uD558\uB2E4\uBA74 \uC704\uD5D8 \uC2E0\uD638\uC785\uB2C8\uB2E4.
      \uC81C\uC774\uB4DC\uAC00 \uBA3C\uC800 \uD655\uC778\uD558\uB7EC \uAC11\uB2C8\uB2E4."
    imageKey: SeungwooFigure&JadeFigure
